{
  "info": {
    "name": "Repository Forge API",
    "description": "Postman collection for Repository Forge blueprint discovery, planning and validation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List blueprints",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/blueprints",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "blueprints"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Inspect blueprint",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/blueprints/{{blueprintId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "blueprints",
            "{{blueprintId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List maturity levels",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/maturity-levels",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "maturity-levels"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List project artifacts",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/project-artifacts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "project-artifacts"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Generate repository plan",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"blueprintId\": \"api-service\",\n  \"projectName\": \"example-api\",\n  \"stackId\": \"node-typescript\",\n  \"maturityLevel\": \"M2\",\n  \"environments\": [\"local\", \"dev\", \"prod\"],\n  \"standardsRefs\": [\"repository-baseline\", \"readme-standard\", \"github-actions-ci-cd\"],\n  \"outputFormat\": \"both\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/plans",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "plans"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Validate repository",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"path\": \"/workspaces/Repository\",\n  \"blueprintId\": \"api-service\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/validate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "validate"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.example.com/repository-forge"
    },
    {
      "key": "blueprintId",
      "value": "api-service"
    }
  ]
}
